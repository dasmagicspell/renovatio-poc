{
    "$id": "https://yourapp.example/schemas/binaural_session.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Binaural Session Plan",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "version",
      "intent",
      "duration_sec",
      "sample_rate_hz",
      "master_gain",
      "binaural",
      "envelope",
      "ambience",
      "safety",
      "metadata"
    ],
    "properties": {
      "version": { "type": "string", "const": "1.0" },
      "intent": {
        "type": "string",
        "enum": ["relax", "exercise", "sleep", "custom"]
      },
      "duration_sec": { "type": "integer", "minimum": 120 },
      "sample_rate_hz": {
        "type": "integer",
        "enum": [44100, 48000]
      },
      "master_gain": { "type": "number", "minimum": -60, "maximum": 0 },
  
      "binaural": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mode", "carrier_wave"],
        "properties": {
          "mode": { "type": "string", "enum": ["fixed", "ramp", "steps"] },
          "carrier_wave": { "type": "string", "enum": ["sine", "triangle", "saw", "square", "noise"] },
          "stereo_balance": { "type": "number", "minimum": -1.0, "maximum": 1.0 },
          "left_base_hz": { "type": "number", "minimum": 80, "maximum": 1000 },
          "right_base_hz": { "type": "number", "minimum": 80, "maximum": 1000 },
          "beat_hz": { "type": "number", "minimum": 0.5, "maximum": 20 },
          "gain_db": { "type": "number", "minimum": -80, "maximum": 0 },
  
          "segments": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "t_start": { "type": "number", "minimum": 0 },
                "t_end": { "type": "number", "exclusiveMinimum": 0 },
                "gain_db": { "type": "number", "minimum": -80, "maximum": 0 },
                "left_base_hz": { "type": "number", "minimum": 80, "maximum": 1000 },
                "right_base_hz": { "type": "number", "minimum": 80, "maximum": 1000 },
  
                "beat_hz": { "type": "number", "minimum": 0.5, "maximum": 20 },
  
                "beat_hz_ramp": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["from", "to"],
                  "properties": {
                    "from": { "type": "number", "minimum": 0.5, "maximum": 20 },
                    "to": { "type": "number", "minimum": 0.5, "maximum": 20 }
                  }
                }
              }
            }
          }
        },
  
        "allOf": [
          {
            "if": { "properties": { "mode": { "const": "fixed" } } },
            "then": {
              "required": ["left_base_hz", "right_base_hz", "beat_hz"],
              "properties": {
                "segments": { "maxItems": 0 }
              }
            }
          },
          {
            "if": { "properties": { "mode": { "const": "ramp" } } },
            "then": {
              "required": ["segments"],
              "properties": {
                "segments": {
                  "minItems": 1,
                  "maxItems": 1,
                  "items": {
                    "required": ["t_start", "t_end", "beat_hz_ramp"],
                    "not": { "required": ["beat_hz"] }
                  }
                },
                "left_base_hz": { "type": ["number", "null"] },
                "right_base_hz": { "type": ["number", "null"] },
                "beat_hz": { "type": ["number", "null"] }
              }
            }
          },
          {
            "if": { "properties": { "mode": { "const": "steps" } } },
            "then": {
              "required": ["segments"],
              "properties": {
                "segments": {
                  "minItems": 1,
                  "items": {
                    "required": ["t_start", "t_end", "beat_hz"]
                  }
                },
                "beat_hz": { "type": ["number", "null"] }
              }
            }
          }
        ]
      },
  
      "envelope": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fade_in_sec", "fade_out_sec"],
        "properties": {
          "fade_in_sec": { "type": "number", "minimum": 0, "maximum": 120 },
          "fade_out_sec": { "type": "number", "minimum": 0, "maximum": 180 }
        }
      },
  
      "ambience": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "gain_db"],
          "properties": {
            "type": { "type": "string", "enum": ["pink_noise", "white_noise", "ocean", "rain", "forest", "stream", "wind"] },
            "gain_db": { "type": "number", "minimum": -80, "maximum": 0 },
            "lowpass_hz": { "type": "number", "minimum": 50, "maximum": 20000 },
            "highpass_hz": { "type": "number", "minimum": 20, "maximum": 5000 },
            "stereo_width": { "type": "number", "minimum": 0, "maximum": 1 },
            "pattern": { "type": "string", "enum": ["steady", "swell"] },
            "pattern_params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "period_sec": { "type": "number", "minimum": 2, "maximum": 60 },
                "depth_db": { "type": "number", "minimum": 0, "maximum": 12 }
              }
            }
          }
        }
      },
  
      "modulation": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "amplitude_mod_hz": { "type": "number", "minimum": 0, "maximum": 2 },
          "frequency_mod_hz": { "type": "number", "minimum": 0, "maximum": 2 },
          "dither": { "type": "boolean" }
        },
        "default": {}
      },
  
      "narration": {
        "type": "object",
        "additionalProperties": false,
        "required": ["enabled"],
        "properties": {
          "enabled": { "type": "boolean" },
          "script": { "type": "string" },
          "cues": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["t", "text"],
              "properties": {
                "t": { "type": "number", "minimum": 0 },
                "text": { "type": "string" }
              }
            }
          }
        }
      },
  
      "safety": {
        "type": "object",
        "additionalProperties": false,
        "required": ["max_peak_db", "limit_true_peak"],
        "properties": {
          "max_peak_db": { "type": "number", "minimum": -12, "maximum": -0.1 },
          "limit_true_peak": { "type": "boolean" }
        }
      },
  
      "metadata": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "author", "tags"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "author": { "type": "string", "minLength": 1 },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 12
          }
        }
      }
    }
  }